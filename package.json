{
  "name": "usdty-token",
  "version": "1.0.0",
  "description": "USDTY - Swappable and Tradeable Stablecoin with USDT Parity",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:ethereum": "hardhat run scripts/deploy.js --network ethereum",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:bsc": "hardhat run scripts/deploy.js --network bsc",
    "deploy:bsc-testnet": "hardhat run scripts/deploy.js --network bscTestnet",
    "deploy:all": "bash deploy.sh",
    "verify:ethereum": "hardhat run scripts/verify.js --network ethereum",
    "verify:bsc": "hardhat run scripts/verify.js --network bsc",
    "etherscan:verify": "hardhat verify",
    "gas-report": "REPORT_GAS=true hardhat test",
    "clean": "hardhat clean",
    "node": "hardhat node"
  },
  "keywords": [
    "ethereum",
    "bnb",
    "stablecoin",
    "usdty",
    "defi",
    "token",
    "erc20",
    "swap",
    "trading",
    "order-book"
  ],
